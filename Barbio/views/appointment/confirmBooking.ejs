<% layout("layouts/boilerplate") -%>
<h2>Confirm Your Booking</h2>

<p><strong>Shop:</strong> <%= shop.name %></p>

<p><strong>Services:</strong></p>
<ul>
    <% bookingData.services.forEach(s => { %>
        <li><%= s.name %> - <%= s.duration %> min - ₹<%= s.price %></li>
    <% }) %>
</ul>

<p><strong>Total Duration:</strong> <%= formattedDuration %></p>
<p><strong>Total Price:</strong> ₹<%= totalPrice %></p>
<p><strong>Date:</strong> <%= bookingData.date %></p>
<p><strong>Time:</strong> <%= formattedTime %></p>

<form id="confirmForm" action="/shops/<%= shop._id %>/book/confirm" method="POST">
    <button type="button" onclick="showAlert()"> Confirm Appointment</button>
</form>

<div style="margin-top: 15px;">
    <a href="/shops/<%= shop._id %>/book/availability">Change Slot</a> |
    <a href="/shops/<%= shop._id %>/book/services">Change Services</a>
</div>
