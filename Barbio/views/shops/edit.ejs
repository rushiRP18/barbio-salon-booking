<% layout("layouts/boilerplate") -%>
    <h2>Edit Listing</h2>
    <form id="addShopForm" method="POST" action="/admin/shops/<%= shop._id %>?_method=PUT">
        <!-- Shop Name -->
        <label for="name">Shop Name</label>
        <input type="text" name="shop[name]" placeholder="Enter the shop name" value="<%= shop.name  %>" required>
        <br>
        <!-- Location -->
        <!-- <label for="longitude">Longitude</label>
        <input type="number" step="0.000001" name="shop[location][coordinates][]" placeholder="Enter longitude"
            required>
        <label for="latitude">Latitude</label>
        <input type="number" step="0.000001" name="shop[location][coordinates][]" placeholder="Enter latitude" required>
        <br> -->
        <!-- Address & Pincode -->
        <!-- Address & Pincode -->
        <label for="address">Address</label>
        <input type="text" id="address" name="shop[address]" placeholder="Enter address" value="<%= shop.address %>"
            required>

        <!-- Hidden fields in GeoJSON order -->
        <input type="hidden" id="longitude" name="shop[location][coordinates][]"
            value="<%= shop.location.coordinates[0] %>" />
        <input type="hidden" id="latitude" name="shop[location][coordinates][]"
            value="<%= shop.location.coordinates[1] %>" />
            
        <input type="hidden" name="shop[location][type]" value="Point" />
    

        <label for="pincode">Pincode</label>
        <input type="number" id="pincode" name="shop[pincode]" placeholder="Enter pincode" value="<%= shop.pincode %>"
            required>

        <!-- Button to fetch live location -->
        <button type="button" onclick="getCurrentLocation()"> Use My Current Location</button>

        <br><br>
        <label for="locationSearch">Search Location</label>
        <div style="display:flex; gap:10px; margin-bottom:10px;">
            <input type="text" id="locationSearch" placeholder="Search for location" style="flex:1; padding:8px;">
            <button type="button" id="searchBtn">Search</button>
        </div>

        <!-- Map -->
        <div id="map" style="width:100%; height:400px; margin-top:10px;"></div>

        <label for="pincode">Available Seats</label>
        <input type="number" name="shop[chairs]" placeholder="Enter nos of chairs" value="<%= shop.chairs %>">

        <br>
        <!-- Services (add multiple services) -->
        <div id="services">
            <h4>Services</h4>

            <% if (shop.services && shop.services.length> 0) { %>
                <% shop.services.forEach((service, index)=> { %>
                    <div class="service">
                        <input type="text" name="shop[services][<%= index %>][name]" placeholder="Service Name"
                            value="<%= service.name %>" required>

                        <input type="text" name="shop[services][<%= index %>][description]" placeholder="Description"
                            value="<%= service.description %>">

                        <input type="number" name="shop[services][<%= index %>][price]" placeholder="Price"
                            value="<%= service.price %>" required>

                        <input type="number" name="shop[services][<%= index %>][duration]"
                            placeholder="Duration (minutes)" value="<%= service.duration %>" required>

                        <button type="button" onclick="removeService(this)">Delete</button>
                    </div>
                    <% }); %>
                        <% } else { %>
                            <div class="service">
                                <input type="text" name="shop[services][0][name]" placeholder="Service Name" required>
                                <input type="text" name="shop[services][0][description]" placeholder="Description">
                                <input type="number" name="shop[services][0][price]" placeholder="Price" required>
                                <input type="number" name="shop[services][0][duration]" placeholder="Duration (minutes)"
                                    required>
                                <button type="button" onclick="removeService(this)">Delete</button>
                            </div>
                            <% } %>
        </div>

        <button type="button" onclick="addService()">Add Service</button>

        <br>
        <!-- Timing -->
        <label for="opensAt">Opens At (hour in 24h format)</label>
        <input type="number" name="shop[timing][opensAt]" min="0" max="23" value="<%= shop.timing.opensAt %>" required>

        <label for="closesAt">Closes At (hour in 24h format)</label>
        <input type="number" name="shop[timing][closesAt]" min="0" max="23" value="<%=shop.timing.closesAt%>" required>

        <!-- Appointments (optional, usually auto-handled) -->
        <!-- <input type="text" name="shop[appointments][]" placeholder="Appointment ID"> -->

        <br>
        <button type="button" onclick="editShop()">Edit Shop</button>
    </form>

    <script>
        let serviceCount = <% - JSON.stringify((shop && shop.services) ? shop.services.length : 1) %>;

        function addService() {
            const serviceDiv = document.createElement('div');
            serviceDiv.classList.add('service');

            serviceDiv.innerHTML = `
            <input type="text" name="shop[services][${serviceCount}][name]" placeholder="Service Name" required>
            <input type="text" name="shop[services][${serviceCount}][description]" placeholder="Description">
            <input type="number" name="shop[services][${serviceCount}][price]" placeholder="Price" required>
            <input type="number" name="shop[services][${serviceCount}][duration]" placeholder="Duration (minutes)" required>
            <button type="button" onclick="removeService(this)">Delete</button>
        `;

            document.getElementById('services').appendChild(serviceDiv);
            serviceCount++;
        }

        function removeService(button) {
            button.parentElement.remove();
        }
    </script>

    <!-- Leaflet CSS & JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
    let map, marker;
    const LOCATIONIQ_API_KEY = "pk.4b10775317572501ecda5e8a469ba38d";

    function initMap() {
        // Use existing shop location as starting point
        const lat = <%= shop.location.coordinates[1] %>;
        const lng = <%= shop.location.coordinates[0] %>;

        map = L.map("map").setView([lat, lng], 15);

        L.tileLayer(`https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png`, {
            attribution: '&copy; <a href="https://www.openstreetmap.org/">OSM</a> contributors'
        }).addTo(map);

        marker = L.marker([lat, lng], { draggable: true }).addTo(map);

        marker.on("dragend", () => {
            const pos = marker.getLatLng();
            updateLocation(pos.lat, pos.lng);
        });

        map.on("click", (e) => {
            marker.setLatLng(e.latlng);
            updateLocation(e.latlng.lat, e.latlng.lng);
        });
    }

    function getCurrentLocation() {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition((position) => {
                const lat = position.coords.latitude;
                const lng = position.coords.longitude;
                map.setView([lat, lng], 15);
                marker.setLatLng([lat, lng]);
                updateLocation(lat, lng);
            }, () => {
                alert("Location access denied.");
            });
        }
    }

    async function updateLocation(lat, lng) {
        document.getElementById("latitude").value = lat;
        document.getElementById("longitude").value = lng;

        try {
            const res = await fetch(
                `https://us1.locationiq.com/v1/reverse?key=${LOCATIONIQ_API_KEY}&lat=${lat}&lon=${lng}&format=json&accept-language=en`
            );
            const data = await res.json();
            if (data && data.display_name) {
                document.getElementById("address").value = data.display_name;
                if (data.address && data.address.postcode) {
                    document.getElementById("pincode").value = data.address.postcode;
                }
            }
        } catch (err) {
            console.error("LocationIQ error:", err);
        }
    }

    async function searchLocation() {
        const query = document.getElementById("locationSearch").value.trim();
        if (!query) return;

        try {
            const res = await fetch(
                `https://us1.locationiq.com/v1/search?key=${LOCATIONIQ_API_KEY}&q=${encodeURIComponent(query)}&format=json&limit=1&accept-language=en`
            );
            const results = await res.json();
            if (results && results.length > 0) {
                const lat = results[0].lat;
                const lon = results[0].lon;
                map.setView([lat, lon], 15);
                marker.setLatLng([lat, lon]);
                updateLocation(lat, lon);
            } else {
                alert("No results found.");
            }
        } catch (err) {
            console.error("Search error:", err);
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        initMap();
        document.getElementById("searchBtn").addEventListener("click", searchLocation);
        document.getElementById("locationSearch").addEventListener("keydown", (e) => {
            if (e.key === "Enter") {
                e.preventDefault();
                searchLocation();
            }
        });
    });
</script>