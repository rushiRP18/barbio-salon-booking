



<% layout("layouts/boilerplate") -%>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <div class="container mt-5">
    <h2 class="mb-4 text-center">Your Appointments</h2>

    <% if (appointments.length===0) { %>
      <div class="alert alert-info text-center">
        No appointments found.
      </div>
      <% } else { %>

        <!-- Filter Buttons -->
        <div class="d-flex justify-content-center mb-4">
          <button class="btn btn-outline-primary me-2 filter-btn active" data-status="all">All</button>
          <button class="btn btn-outline-warning me-2 filter-btn" data-status="pending">Pending</button>
          <button class="btn btn-outline-success me-2 filter-btn" data-status="confirmed">Confirmed</button>
          <button class="btn btn-outline-secondary me-2 filter-btn" data-status="completed">Completed</button>
          <button class="btn btn-outline-danger filter-btn" data-status="cancelled">Cancelled</button>
        </div>

        <!-- Appointments Grid -->
        <div class="row" id="appointments-container">
          <% appointments.forEach(app=> { %>
            <div class="col-md-6 col-lg-4 mb-4 appointment-card" data-status="<%= app.status %>">
              <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                  <h5 class="card-title text-primary">
                    <i class="bi bi-scissors"></i>
                    <%= app.shopName %>
                  </h5>
                  <p class="mb-2"><strong>Services:</strong>
                    <%= app.services %>
                  </p>
                  <p class="mb-2"><strong>Total Price:</strong> ₹<%= app.totalPrice %>
                  </p>
                  <p class="mb-2"><strong>Time:</strong>
                    <%= app.time %>
                  </p>
                  <p class="mb-2"><strong>Date:</strong>
                    <%= app.date.toDateString() %>
                  </p>

                  <% if (app.status==='pending' ) { %>
                    <span class="badge bg-warning text-dark">Pending</span>
                    <% } else if (app.status==='confirmed' ) { %>
                      <span class="badge bg-success">Confirmed</span>
                      <% } else if (app.status==='completed' ) { %>
                        <span class="badge bg-secondary">Completed</span>
                        <% } else if (app.status==='cancelled' ) { %>
                          <span class="badge bg-danger">Cancelled</span>
                          <% } else { %>
                            <span class="badge bg-dark">
                              <%= app.status %>
                            </span>
                            <% } %>
                </div>
                <% if (app.shopLat && app.shopLng) { %>
                  <button class="btn btn-primary mt-2 show-directions-btn" data-lat="<%= app.shopLat %>"
                    data-lng="<%= app.shopLng %>">
                    <i class="bi bi-geo-alt-fill"></i> Show Directions
                  </button>
                  <% } else { %>
                    <p class="text-muted">No location available</p>
                    <% } %>


                      <div class="card-footer text-muted text-center">
                        Booking ID: <%= app.id %>
                      </div>
              </div>
            </div>
            <% }) %>
        </div>
        <% } %>
  </div>

  <script>
    // Filtering logic
    document.querySelectorAll(".show-directions-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        const lat = btn.getAttribute("data-lat");
        const lng = btn.getAttribute("data-lng");

        if (lat && lng) {
          if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition((position) => {
              const userLat = position.coords.latitude;
              const userLng = position.coords.longitude;

              // Open Google Maps with both origin & destination
              const url = `https://www.google.com/maps/dir/?api=1&origin=${userLat},${userLng}&destination=${lat},${lng}`;

              window.open(url, "_blank");
            }, () => {
              // fallback → only destination
             const url = `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`;

              window.open(url, "_blank");
            });
          } else {
            alert("Geolocation is not supported by this browser.");
          }
        } else {
          alert("Shop location not available.");
        }
      });
    });

  </script>

  <script>
  // Filtering logic
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const status = btn.getAttribute('data-status');

      // Highlight active button
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Show/Hide cards
      document.querySelectorAll('.appointment-card').forEach(card => {
        if (status === "all" || card.getAttribute('data-status') === status) {
          card.style.display = "block";
        } else {
          card.style.display = "none";
        }
      });
    });
  });
</script>

<script src="/public/js/subscribe.js"></script>