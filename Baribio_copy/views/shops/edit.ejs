<% layout("layouts/boilerplate") -%>

<div class="add-shop-page">
    <div class="shop-form-wrapper">
        
        <div class="form-header">
            <a href="/shops/<%= shop._id %>" class="sub-title">
                <i class="fa-solid fa-arrow-left"></i> Back to Shop
            </a>
            <h1>Edit Shop Details</h1>
        </div>

        <form id="addShopForm" method="POST" action="/admin/shops/<%= shop._id %>?_method=PUT">
            
            <div class="form-group">
                <label for="name">Shop Name:</label>
                <input type="text" name="shop[name]" placeholder="Enter shop name" value="<%= shop.name %>" required>
            </div>
            <div class="form-group">
                <label for="image">Shop Image:</label>
                <input name="shop[image]" type="text" placeholder="Paste the image url" value="<%= shop.image %>" required>
            </div>
            <div class="form-group">
                <label for="address">Address:</label>
                <input type="text" id="address" name="shop[address]" placeholder="Full address" value="<%= shop.address %>" required>
            </div>

            <div class="form-row">
                <div class="form-group flex-grow">
                    <label for="pincode">Pincode:</label>
                    <input type="number" id="pincode" name="shop[pincode]" placeholder="123456" value="<%= shop.pincode %>" required>
                </div>
                <button type="button" class="btn-outline-location" onclick="getCurrentLocation()">
                    <i class="fa-solid fa-location-crosshairs"></i> Use current Location
                </button>
            </div>

            <input type="hidden" id="longitude" name="shop[location][coordinates][]" value="<%= shop.location.coordinates[0] %>" />
            <input type="hidden" id="latitude" name="shop[location][coordinates][]" value="<%= shop.location.coordinates[1] %>" />
            <input type="hidden" name="shop[location][type]" value="Point" />

            <div class="divider">UPDATE LOCATION</div>

            <div class="search-box">
                <input type="text" id="locationSearch" placeholder="Search new location">
                <button type="button" id="searchBtn"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>

            <div id="map" style="width:100%; height:300px; border-radius:15px; margin-bottom: 20px;"></div>

            <div class="services-section">
                <h3>Manage Services</h3>

                <div id="services-container">
                    <% if (shop.services && shop.services.length > 0) { %>
                        <% shop.services.forEach((service, index) => { %>
                            <div class="service-item mt-3">
                                <button type="button" class="btn-delete-service" onclick="removeService(this)">
                                    <i class="fa-solid fa-times"></i>
                                </button>
                                
                                <div class="service-grid">
                                    <input type="text" name="shop[services][<%= index %>][name]" placeholder="Service Name" value="<%= service.name %>" required>
                                    <input type="text" name="shop[services][<%= index %>][description]" placeholder="Description" value="<%= service.description %>">
                                    <input type="number" name="shop[services][<%= index %>][price]" placeholder="Price" value="<%= service.price %>" required>
                                    <input type="number" name="shop[services][<%= index %>][duration]" placeholder="Duration (min)" value="<%= service.duration %>" required>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="service-item mt-3">
                            <div class="service-grid">
                                <input type="text" name="shop[services][0][name]" placeholder="Service Name" required>
                                <input type="text" name="shop[services][0][description]" placeholder="Description">
                                <input type="number" name="shop[services][0][price]" placeholder="Price" required>
                                <input type="number" name="shop[services][0][duration]" placeholder="Duration (min)" required>
                            </div>
                        </div>
                    <% } %>
                </div>

                <button type="button" class="btn-add-service" onclick="addService()">
                    <i class="fa-solid fa-plus"></i> Add Service
                </button>
            </div>

            <div class="form-group mt-5" style="text-align: center;">
                <label for="chairs">Available Seats:</label>
                <div style="display: flex; justify-content: center;">
                    <input type="number" name="shop[chairs]" placeholder="e.g. 3" value="<%= shop.chairs %>" style="width: 120px; text-align: center;">
                </div>
            </div>

            <div class="timings-section">
                <h3>Timings (24h format)</h3>
                <div class="form-row justify-center gap-20">
                    <div class="time-input">
                        <label>Open</label>
                        <input type="number" name="shop[timing][opensAt]" min="0" max="23" value="<%= shop.timing.opensAt %>" required>
                    </div>
                    <div class="time-input">
                        <label>Closes</label>
                        <input type="number" name="shop[timing][closesAt]" min="0" max="23" value="<%=shop.timing.closesAt%>" required>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="button" class="btn-create" onclick="updateShop()">Update Changes</button>
            </div>

        </form>
    </div>

    <div id="confirmationModal" class="modal">
        <div class="modal-content">
            <h3>Save Changes?</h3>
            <p>Are you sure you want to update this shop's details?</p>
            <div class="modal-actions">
                <button id="confirmBtn" class="btn confirm">Yes, Update</button>
                <button id="cancelBtn" class="btn cancel">Cancel</button>
            </div>
        </div>
    </div>

</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
    // Initialize service count safely based on existing services
    let serviceCount = <%= (shop && shop.services) ? shop.services.length : 1 %>;

    function addService() {
        const serviceDiv = document.createElement('div');
        serviceDiv.classList.add('service-item', 'mt-3');

        serviceDiv.innerHTML = `
            <button type="button" class="btn-delete-service" onclick="removeService(this)">
                <i class="fa-solid fa-times"></i>
            </button>
            <div class="service-grid">
                <input type="text" name="shop[services][${serviceCount}][name]" placeholder="Service Name" required>
                <input type="text" name="shop[services][${serviceCount}][description]" placeholder="Description">
                <input type="number" name="shop[services][${serviceCount}][price]" placeholder="Price" required>
                <input type="number" name="shop[services][${serviceCount}][duration]" placeholder="Duration (min)" required>
            </div>
        `;

        document.getElementById('services-container').appendChild(serviceDiv);
        serviceCount++;
    }

    function removeService(button) {
        // Removes the .service-item div
        button.parentElement.remove();
    }

    // Modal Logic
    function updateShop() {
        const form = document.getElementById('addShopForm');
        if (form.checkValidity()) {
            document.getElementById('confirmationModal').style.display = 'flex';
        } else {
            form.reportValidity();
        }
    }

    document.getElementById('cancelBtn').onclick = () => {
        document.getElementById('confirmationModal').style.display = 'none';
    };
    document.getElementById('confirmBtn').onclick = () => {
        document.getElementById('addShopForm').submit();
    };
    window.onclick = (event) => {
        const modal = document.getElementById('confirmationModal');
        if (event.target == modal) {
            modal.style.display = "none";
        }
    }
</script>

<script>
    let map, marker;
    const LOCATIONIQ_API_KEY = "pk.4b10775317572501ecda5e8a469ba38d";

    function initMap() {
        // Use existing shop location as starting point
        const lat = <%= shop.location.coordinates[1] %>;
        const lng = <%= shop.location.coordinates[0] %>;

        map = L.map("map").setView([lat, lng], 15);

        L.tileLayer(`https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png`, {
            attribution: '&copy; <a href="https://www.openstreetmap.org/">OSM</a> contributors'
        }).addTo(map);

        marker = L.marker([lat, lng], { draggable: true }).addTo(map);

        marker.on("dragend", () => {
            const pos = marker.getLatLng();
            updateLocation(pos.lat, pos.lng);
        });

        map.on("click", (e) => {
            marker.setLatLng(e.latlng);
            updateLocation(e.latlng.lat, e.latlng.lng);
        });
    }

    function getCurrentLocation() {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition((position) => {
                const lat = position.coords.latitude;
                const lng = position.coords.longitude;
                map.setView([lat, lng], 15);
                marker.setLatLng([lat, lng]);
                updateLocation(lat, lng);
            }, () => {
                alert("Location access denied.");
            });
        }
    }

    async function updateLocation(lat, lng) {
        document.getElementById("latitude").value = lat;
        document.getElementById("longitude").value = lng;

        try {
            const res = await fetch(
                `https://us1.locationiq.com/v1/reverse?key=${LOCATIONIQ_API_KEY}&lat=${lat}&lon=${lng}&format=json&accept-language=en`
            );
            const data = await res.json();
            if (data && data.display_name) {
                document.getElementById("address").value = data.display_name;
                if (data.address && data.address.postcode) {
                    document.getElementById("pincode").value = data.address.postcode;
                }
            }
        } catch (err) {
            console.error("LocationIQ error:", err);
        }
    }

    async function searchLocation() {
        const query = document.getElementById("locationSearch").value.trim();
        if (!query) return;

        try {
            const res = await fetch(
                `https://us1.locationiq.com/v1/search?key=${LOCATIONIQ_API_KEY}&q=${encodeURIComponent(query)}&format=json&limit=1&accept-language=en`
            );
            const results = await res.json();
            if (results && results.length > 0) {
                const lat = results[0].lat;
                const lon = results[0].lon;
                map.setView([lat, lon], 15);
                marker.setLatLng([lat, lon]);
                updateLocation(lat, lon);
            } else {
                alert("No results found.");
            }
        } catch (err) {
            console.error("Search error:", err);
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        initMap();
        document.getElementById("searchBtn").addEventListener("click", searchLocation);
        document.getElementById("locationSearch").addEventListener("keydown", (e) => {
            if (e.key === "Enter") {
                e.preventDefault();
                searchLocation();
            }
        });
    });
</script>