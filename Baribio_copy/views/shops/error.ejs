<% layout("layouts/boilerplate") -%>

<style>
    /* =========================================
       404 PAGE - DARK LUXURY THEME
       ========================================= */

    /* 1. Centering Wrapper */
    .error-page-wrapper {
        /* Forces content to center vertically & horizontally */
        min-height: 100vh; 
        padding-top: 4rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #0d0d0d;
        color: #fff;
        font-family: 'Urbanist', sans-serif;
    }

    .error-content {
        text-align: center;
        max-width: 600px;
        padding: 20px;
    }

    /* 2. The Ghost SVG (Theme Adapted) */
    .ghost-svg {
        width: 160px;
        margin-bottom: 20px;
        animation: float 3s ease-in-out infinite;
        
        /* Gold Glow */
        filter: drop-shadow(0 0 15px rgba(214, 185, 166, 0.2)); 
    }

    /* SVG Animation */
    @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
        100% { transform: translateY(0px); }
    }
    
    .ghost-eyes { animation: blink 4s infinite; transform-origin: center; }
    @keyframes blink {
        0%, 96%, 100% { transform: scaleY(1); }
        98% { transform: scaleY(0.1); }
    }

    /* 3. Typography */
    .error-code {
        font-size: 8rem;
        font-weight: 700;
        line-height: 1;
        color: #1a1a1a; /* Dark text */
        
        /* Gold Outline Text Effect */
        -webkit-text-stroke: 2px #D6B9A6; 
        margin-bottom: 0;
        opacity: 0.8;
    }

    .error-heading {
        font-size: 1.8rem;
        color: #D6B9A6; /* Gold */
        margin-bottom: 15px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .error-desc {
        color: #888;
        font-size: 1.1rem;
        margin-bottom: 40px;
        line-height: 1.6;
    }

    /* 4. The Gold Pill Button (Same as Shopkeeper page) */
    .gold-btn-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        
        /* The thin gold border */
        padding: 2px;
        
        width: 14rem;
        border-radius: 40px;
        background-color: #D6B9A6;
        transition: transform 0.3s ease;
    }

    .gold-btn-wrapper a {
        display: flex;
        width: 100%;
        height: 100%;
        text-decoration: none;
    }

    .inner-btn {
        width: 100%;
        padding: 1rem 0;
        
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px; /* Space between icon and text */
        
        font-size: 1.1rem;
        font-weight: bold;
        border: none;
        border-radius: 38px;
        
        background-color: #0d0d0d; /* Dark matching bg */
        color: white;
        transition: all 0.3s ease-in-out;
    }

    /* Hover Effects */
    .inner-btn:hover {
        background-color: #D6B9A6;
        color: #0d0d0d;
    }

    .gold-btn-wrapper:hover {
        transform: scale(1.05);
    }

</style>

<div class="error-page-wrapper">
    <div class="error-content">
        
        <svg class="ghost-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <path d="M100,20 C60,20 30,50 30,90 L30,170 Q40,190 50,170 T70,170 T90,170 T110,170 T130,170 T150,170 T170,170 L170,90 C170,50 140,20 100,20 Z" 
                  fill="#f5f5f5" stroke="#D6B9A6" stroke-width="4"/>
            
            <ellipse cx="100" cy="190" rx="60" ry="10" fill="#000" opacity="0.5" />

            <g class="ghost-eyes">
                <circle cx="75" cy="80" r="8" fill="#0d0d0d"/>
                <circle cx="125" cy="80" r="8" fill="#0d0d0d"/>
            </g>
            <circle cx="100" cy="110" r="10" fill="#0d0d0d"/>
            
            <ellipse cx="65" cy="100" rx="8" ry="5" fill="#D6B9A6" opacity="0.6"/>
            <ellipse cx="135" cy="100" rx="8" ry="5" fill="#D6B9A6" opacity="0.6"/>
        </svg>

        <div class="error-code">404</div>
        <div class="error-heading">Lost in the shadows?</div>
        
        <p class="error-desc">
            The page you are looking for has vanished. It might have been moved, deleted, or perhaps it never existed in this timeline.
        </p>

        <div class="gold-btn-wrapper">
            <a href="/">
                <div class="inner-btn">
                    <i class="fa-solid fa-house"></i>
                    Return Home
                </div>
            </a>
        </div>

    </div>
</div>