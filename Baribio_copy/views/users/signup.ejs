<% layout("layouts/boilerplate") -%>

<div class="su-page">
    <div class="su-glass-card">
        
        <h1 class="su-brand-title">Barbio</h1>
        <p class="su-tagline">Create your new account</p>

        <form action="/signup" method="POST" class="su-form">
            
            <div class="su-grid">
                
                <div class="su-input-group">
                    <label for="username">Username</label>
                    <input type="text" name="username" id="username" required>
                </div>

                <div class="su-input-group">
                    <label for="email">E-mail</label>
                    <input type="email" name="email" id="email" required>
                </div>

                <div class="su-input-group">
                    <label for="contactNo">Contact</label>
                    <input type="number" name="contactNo" id="contactNo" required>
                </div>

                <div class="su-input-group">
                    <label for="role">Role</label>
                    <div class="su-select-wrapper">
                        <select name="role" id="role" required>
                            <option value="" disabled selected>Select Role</option>
                            <option value="user">User</option>
                            <option value="shopkeeper">Shopkeeper</option>
                        </select>
                        <i class="fa-solid fa-chevron-down su-select-icon"></i>
                    </div>
                </div>

                <div class="su-input-group su-full-width">
                    <label for="password">Password</label>
                    <input type="password" name="password" id="password" required>
                </div>

            </div>

            <div class="su-footer">
                <button class="su-btn-signup">
                    Sign Up <i class="fa-solid fa-arrow-right"></i>
                </button>
                <a href="/login" class="su-link-login">Already have an account?</a>
            </div>

        </form>
    </div>
</div>