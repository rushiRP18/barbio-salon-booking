<style>
    /* =========================================
   FOOTER - DARK LUXURY THEME
   ========================================= */

.barbio-footer {
    background-color: #0d0d0d; /* Deep Black */
    color: #fff;
    font-family: 'Urbanist', sans-serif;
    padding: 80px 20px 30px 20px;
    border-top: 1px solid #222; /* Subtle separation from content */
    margin-top: auto; /* Pushes footer to bottom if content is short */
}

.footer-container {
    max-width: 1200px;
    margin: 0 auto;
}

/* --- Top Section Layout --- */
.footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr; /* Brand column is wider */
    gap: 40px;
    margin-bottom: 60px;
}

/* Brand Column */
.footer-logo {
    font-size: 2rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 15px;
}

.footer-tagline {
    color: #888;
    line-height: 1.6;
    margin-bottom: 25px;
    font-size: 0.95rem;
}

/* Social Icons (Gold Hover) */
.footer-socials {
    display: flex;
    gap: 15px;
}

.social-btn {
    width: 40px;
    height: 40px;
    background-color: #1a1a1a;
    border: 1px solid #333;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #aaa;
    text-decoration: none;
    transition: all 0.3s ease;
}

.social-btn:hover {
    background-color: #D6B9A6;
    color: #000;
    border-color: #D6B9A6;
    transform: translateY(-3px);
}

/* --- Link Columns --- */
.footer-col h4 {
    color: #D6B9A6; /* Gold Headers */
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 25px;
    letter-spacing: 0.5px;
}

.footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
}

.footer-col ul li {
    margin-bottom: 12px;
}

.footer-col ul li a {
    color: #888;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s ease;
    position: relative;
}

/* Hover Effect for Links */
.footer-col ul li a:hover {
    color: #fff;
    padding-left: 5px; /* Subtle movement */
}

/* --- Divider & Bottom --- */
.footer-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, #333, transparent); /* Faded ends */
    margin-bottom: 30px;
}

.footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #555;
    font-size: 0.9rem;
}

.made-with i {
    color: #D6B9A6;
    margin: 0 3px;
    animation: heartbeat 1.5s infinite;
}

@keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
}

/* --- Mobile Responsiveness --- */
@media (max-width: 992px) {
    .footer-top {
        grid-template-columns: 1fr 1fr; /* 2 columns on tablet */
        gap: 30px;
    }
}

@media (max-width: 576px) {
    .footer-top {
        grid-template-columns: 1fr; /* 1 column on mobile */
        text-align: center;
    }
    
    .footer-socials {
        justify-content: center;
    }
    
    .footer-bottom {
        flex-direction: column;
        gap: 10px;
    }
}
</style>
<footer class="barbio-footer">
    <div class="footer-container">
        
        <div class="footer-top">
            <div class="footer-brand-col">
                <a href="/" class="footer-logo">Barbio</a>
                <p class="footer-tagline">
                    Redefining the salon experience. <br>
                    Book appointments, skip the queue, look your best.
                </p>
                
                <div class="footer-socials">
                    <a href="#" class="social-btn"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" class="social-btn"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#" class="social-btn"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#" class="social-btn"><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>

            <div class="footer-col">
                <h4>Explore</h4>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/shops">Find Services</a></li>
                    <li><a href="/user/appointments">My Bookings</a></li>
                    <li><a href="/contact">Contact Us</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Business</h4>
                <ul>
                    <li><a href="/signup">Partner with us</a></li>
                    <li><a href="/admin/shops">Shop Login</a></li>
                    <li><a href="/admin/new">Add a Salon</a></li>
                    <li><a href="#">Success Stories</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Legal</h4>
                <ul>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Service</a></li>
                    <li><a href="#">Cookie Policy</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-divider"></div>

        <div class="footer-bottom">
            <p>&copy; <%= new Date().getFullYear() %> Barbio Inc. All rights reserved.</p>
            <p class="made-with">Made with <i class="fa-solid fa-heart"></i> by RP@18</p>
        </div>
    </div>
</footer>